<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.inventory.app.mobile.fragments.HomeFragment"
        android:label="Mobile Inventory">
        <action
            android:id="@+id/action_homeFragment_to_pairingFragment"
            app:destination="@id/pairingFragment" />
        <action
            android:id="@+id/action_homeFragment_to_findFragment"
            app:destination="@id/findFragment" />
        <action
            android:id="@+id/action_homeFragment_to_transferListFragment"
            app:destination="@id/transferListFragment" />
        <action
            android:id="@+id/action_homeFragment_to_shipmentListFragment"
            app:destination="@id/shipmentListFragment" />
        <action
            android:id="@+id/action_homeFragment_to_stockOpnameFragment"
            app:destination="@id/stockOpnameFragment" />
        <action
            android:id="@+id/action_homeFragment_to_placementListFragment"
            app:destination="@id/placementListFragment" />
    </fragment>
    <fragment
        android:id="@+id/pairingFragment"
        android:name="com.inventory.app.mobile.fragments.PairingFragment"
        android:label="RFID Pairing"
        tools:layout="@layout/fragment_pairing" />
    <fragment
        android:id="@+id/findFragment"
        android:name="com.inventory.app.mobile.fragments.FindFragment"
        android:label="Find Asset"
        tools:layout="@layout/fragment_find" >
        <action
            android:id="@+id/action_findFragment_to_findScanFragment"
            app:destination="@id/findScanFragment" />
    </fragment>
    <fragment
        android:id="@+id/findScanFragment"
        android:name="com.inventory.app.mobile.fragments.FindScanFragment"
        android:label="Find Asset"
        tools:layout="@layout/fragment_find_scan" >
        <argument
            android:name="epc"
            app:argType="string" />
    </fragment>
    <fragment
        android:id="@+id/transferListFragment"
        android:name="com.inventory.app.mobile.fragments.TransferListFragment"
        android:label="Transfer"
        tools:layout="@layout/fragment_transfer_list" >
        <action
            android:id="@+id/action_transferListFragment_to_transferFragment"
            app:destination="@id/transferFragment" />
        <action
            android:id="@+id/action_transferListFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpToInclusive="true" />
    </fragment>
    <fragment
        android:id="@+id/transferFragment"
        android:name="com.inventory.app.mobile.fragments.TransferFragment"
        android:label="Transfer"
        tools:layout="@layout/fragment_transfer" >
        <argument
            android:name="id"
            app:argType="long" />
        <action
            android:id="@+id/action_transferFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpToInclusive="true" />
    </fragment>
    <fragment
        android:id="@+id/shipmentListFragment"
        android:name="com.inventory.app.mobile.fragments.ShipmentListFragment"
        android:label="Shipment"
        tools:layout="@layout/fragment_shipment_list" >
        <action
            android:id="@+id/action_shipmentListFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_shipmentListFragment_to_shipmentFragment"
            app:destination="@id/shipmentFragment" />
    </fragment>
    <fragment
        android:id="@+id/shipmentFragment"
        android:name="com.inventory.app.mobile.fragments.ShipmentFragment"
        android:label="Shipment"
        tools:layout="@layout/fragment_shipment" >
        <action
            android:id="@+id/action_shipmentFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpToInclusive="true" />
        <argument
            android:name="id"
            app:argType="long" />
    </fragment>
    <fragment
        android:id="@+id/stockOpnameFragment"
        android:name="com.inventory.app.mobile.fragments.StockOpnameFragment"
        android:label="Stock Opname"
        tools:layout="@layout/fragment_stock_opname" >
        <action
            android:id="@+id/action_stockOpnameFragment_to_stockOpnameScanFragment"
            app:destination="@id/stockOpnameScanFragment" />
    </fragment>
    <fragment
        android:id="@+id/stockOpnameScanFragment"
        android:name="com.inventory.app.mobile.fragments.StockOpnameScanFragment"
        android:label="Stock Opname">
        <argument
            android:name="locationId"
            android:defaultValue="0L"
            app:argType="long" />
        <argument
            android:name="shelfId"
            android:defaultValue="0L"
            app:argType="long" />
        <argument
            android:name="shelfSlotId"
            android:defaultValue="0L"
            app:argType="long" />
        <action
            android:id="@+id/action_stockOpnameScanFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
        <argument
            android:name="name"
            app:argType="string" />
    </fragment>
    <fragment
        android:id="@+id/placementListFragment"
        android:name="com.inventory.app.mobile.fragments.PlacementListFragment"
        android:label="@string/placement"
        tools:layout="@layout/fragment_placement_list">
        <action
            android:id="@+id/action_placementListFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
        <action
            android:id="@+id/action_placementListFragment_to_placementFragment"
            app:destination="@id/placementFragment" />
    </fragment>
    <fragment
        android:id="@+id/placementFragment"
        android:name="com.inventory.app.mobile.fragments.PlacementFragment"
        android:label="@string/placement"
        tools:layout="@layout/fragment_placement">
        <action
            android:id="@+id/action_placementFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
        <argument
            android:name="id"
            app:argType="long" />
    </fragment>
</navigation>