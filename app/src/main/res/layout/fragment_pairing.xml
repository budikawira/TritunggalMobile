<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".fragments.PairingFragment"
    android:background="@color/white"
    android:padding="8dp">

    <LinearLayout
        android:paddingTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:id="@+id/layoutBottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnReset"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/reset"
            android:visibility="gone"
            style="@style/SecondaryButtonStyle" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnScan"
            style="@style/SecondaryButtonStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/start_scan"
            android:enabled="false"
            />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnUpload"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/upload"
            android:visibility="gone"
            style="@style/PrimaryButtonStyle"
            android:enabled="false" />
    </LinearLayout>
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAlignment="center"
        android:padding="8dp"
        android:id="@+id/tvAddress"
        android:text="@string/connect_reader"
        app:layout_constraintBottom_toTopOf="@id/layoutBottom"
        />
    <LinearLayout
        android:layout_marginTop="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:id="@+id/layoutPower"
        app:layout_constraintTop_toTopOf="parent">
        <TextView
            android:textSize="12sp"
            android:textAlignment="center"
            android:textColor="@color/primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/rfid_power"
            />
        <TextView
            android:textSize="18sp"
            android:textAlignment="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/textPower"
            android:textStyle="bold"
            android:textColor="@color/accent"
            android:text="-"
            />
    </LinearLayout>
    <LinearLayout
        android:layout_marginTop="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:id="@+id/layoutRfid"
        app:layout_constraintTop_toBottomOf="@id/layoutPower">
        <TextView
            android:textSize="12sp"
            android:textAlignment="center"
            android:textColor="@color/primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/rfid_number"
            />
        <TextView
            android:textSize="18sp"
            android:textAlignment="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/textRfid"
            android:textStyle="bold"
            android:text="-"
            />
    </LinearLayout>
    <LinearLayout
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:id="@+id/layoutQr"
        app:layout_constraintTop_toBottomOf="@id/layoutRfid">
        <TextView
            android:textAlignment="center"
            android:textSize="12sp"
            android:layout_marginEnd="8dp"
            android:textColor="@color/primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/qr_code"
            />
        <TextView
            android:textAlignment="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/textQr"
            android:textSize="18sp"
            android:textStyle="bold"
            android:text="-"
            />
    </LinearLayout>
    <TextView
        app:layout_constraintTop_toBottomOf="@id/layoutQr"
        android:textAlignment="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/textStatus"
        android:textColor="@color/primary"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:textSize="18sp"
        />

    <com.airbnb.lottie.LottieAnimationView
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/textStatus"
        app:layout_constraintBottom_toTopOf="@id/layoutBottom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="invisible"
        android:id="@+id/lottieUpload"
        android:scaleType="fitCenter"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:lottie_rawRes="@raw/anim_upload"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"/>

    <com.airbnb.lottie.LottieAnimationView
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/textStatus"
        app:layout_constraintBottom_toTopOf="@id/tvAddress"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:id="@+id/lottieRfid"
        android:scaleType="fitCenter"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:lottie_rawRes="@raw/anim_rfid_scan"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"/>
    <androidx.camera.view.PreviewView
        android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@id/textStatus"
        app:layout_constraintBottom_toTopOf="@id/tvAddress"
        android:layout_margin="8dp"
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="1:1"
        />
    <com.inventory.app.mobile.views.OverlayView
        android:visibility="invisible"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="@id/previewView"
        app:layout_constraintBottom_toBottomOf="@id/previewView"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintEnd_toEndOf="@id/previewView"
        android:id="@+id/overlayView"
        android:background="@android:color/transparent" />
</androidx.constraintlayout.widget.ConstraintLayout>