<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragments.TransferFragment">
    <ImageButton
        android:id="@+id/btnMore"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:src="@drawable/ic_more_vert"
        style="@style/PrimaryButtonStyle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="4dp"
        android:layout_marginBottom="4dp"
        android:layout_marginTop="4dp"
        />
    <LinearLayout
        android:id="@+id/layoutBottom"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnMore"
        app:layout_constraintEnd_toEndOf="parent"
        tools:ignore="UselessParent">
        <Button
            android:id="@+id/buttonScan"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="56dp"
            style="@style/PrimaryButtonStyle"
            android:text="@string/start_scan"
            />
        <Button
            android:id="@+id/buttonUpload"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="56dp"
            style="@style/SecondaryButtonStyle"
            android:text="@string/upload"
            android:enabled="false"
            />
    </LinearLayout>

    <TextView
        android:id="@+id/textLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        android:textColor="@color/primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:paddingBottom="4dp"
        />
    <LinearLayout
        android:id="@+id/layoutTop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toBottomOf="@id/textLocation"
        android:orientation="horizontal"
        >
        <LinearLayout
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:id="@+id/layoutNotScanned"
            android:orientation="vertical"
            android:padding="8dp"
            android:background="@drawable/border_bg"
            >
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAlignment="center"
                android:textSize="24sp"
                android:id="@+id/textNotScanned"
                android:text="0"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAlignment="center"
                android:textSize="12sp"
                android:id="@+id/lblNotScanned"
                android:text="Not Scanned" />
        </LinearLayout>
        <LinearLayout
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:id="@+id/layoutScanned"
            android:orientation="vertical"
            android:padding="8dp"
            >
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAlignment="center"
                android:textSize="24sp"
                android:id="@+id/textScanned"
                android:text="0"/>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAlignment="center"
                android:textSize="12sp"
                android:id="@+id/lblScanned"
                android:text="Scanned" />
        </LinearLayout>
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/lightGrey"
        app:layout_constraintTop_toBottomOf="@id/layoutTop"
        app:layout_constraintBottom_toTopOf="@id/layoutBottom" />
</androidx.constraintlayout.widget.ConstraintLayout>